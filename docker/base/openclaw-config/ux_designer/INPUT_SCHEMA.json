{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UX Designer Input Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "create_wireframe",
        "map_user_flow",
        "define_design_tokens",
        "spec_component",
        "review_implementation",
        "research_ux",
        "heartbeat",
        "poll_github_queue"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "po",
        "arquiteto",
        "cron"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "us_id": {
          "type": "string",
          "pattern": "^US-\\d{3}-[a-z0-9-]+$"
        },
        "feature_id": {
          "type": "string",
          "pattern": "^FEATURE-\\d{3}-[a-z0-9-]+$"
        },
        "platform": {
          "type": "string",
          "enum": [
            "web",
            "mobile",
            "both"
          ]
        },
        "issue_label": {
          "type": "string",
          "enum": [
            "ux"
          ]
        }
      }
    }
  },
  "required": [
    "intent",
    "source"
  ]
}
