{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DBA DataEngineer Input Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "design_schema",
        "create_migration",
        "optimize_query",
        "lgpd_audit",
        "backup_strategy",
        "data_pipeline",
        "heartbeat",
        "poll_github_queue",
        "research_cost_performance"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "arquiteto",
        "dev_backend",
        "po",
        "ceo",
        "cron"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^TASK-\\d+(?:-[a-z0-9-]+)?$"
        },
        "us_id": {
          "type": "string",
          "pattern": "^US-\\d{3}-[a-z0-9-]+$"
        },
        "db_engine": {
          "type": "string",
          "minLength": 2
        },
        "issue_label": {
          "type": "string",
          "enum": [
            "dba"
          ]
        },
        "target_table": {
          "type": "string"
        },
        "migration_type": {
          "type": "string",
          "enum": [
            "up",
            "down",
            "squash"
          ]
        }
      }
    }
  },
  "required": [
    "intent",
    "source"
  ]
}
