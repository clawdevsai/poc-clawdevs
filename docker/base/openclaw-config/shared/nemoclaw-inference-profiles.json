{
  "defaultProfile": "local-first",
  "profiles": {
    "local-first": {
      "description": "Ollama local as primary, Ollama cloud as fallback",
      "routingOrder": ["ollama-local", "ollama-cloud"],
      "fallbackEnabled": true,
      "timeouts": {
        "requestMs": 60000,
        "connectMs": 5000
      },
      "retryPolicy": {
        "maxAttempts": 2,
        "backoffMs": 500
      }
    }
  },
  "providers": {
    "ollama-local": {
      "type": "ollama",
      "baseUrl": "http://ollama:11434",
      "model": "mistral"
    },
    "ollama-cloud": {
      "type": "ollama",
      "baseUrlEnv": "OLLAMA_CLOUD_BASE_URL",
      "apiKeyEnv": "OLLAMA_CLOUD_API_KEY",
      "modelEnv": "OLLAMA_CLOUD_MODEL"
    }
  }
}
