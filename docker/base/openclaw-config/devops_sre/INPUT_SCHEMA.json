{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevOps SRE Input Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "manage_pipeline",
        "provision_infrastructure",
        "rotate_secrets",
        "monitor_production",
        "generate_prod_metrics",
        "incident_response",
        "ci_cd_failure_triage",
        "github_integration",
        "report_status",
        "poll_github_queue"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "arquiteto",
        "po",
        "ceo"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^TASK-\\d+(?:-[a-z0-9-]+)?$"
        },
        "issue_label": {
          "type": "string",
          "enum": [
            "devops"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2"
          ]
        },
        "infra_type": {
          "type": "string",
          "enum": [
            "kubernetes",
            "terraform",
            "helm",
            "github_actions",
            "docker",
            "cloud"
          ]
        },
        "cloud_provider": {
          "type": "string",
          "enum": [
            "aws",
            "gcp",
            "azure",
            "other"
          ]
        },
        "incident_description": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  },
  "required": [
    "intent",
    "source"
  ]
}
