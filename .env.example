# ClawDevs — variáveis de ambiente (nunca commitar .env com valores reais)
# Copie para .env e preencha: cp .env.example .env

# Telegram (interface Diretor ↔ CEO)
# Bot token: criar em https://t.me/BotFather com /newbot
# Se o token foi exposto em chat ou em arquivo, revogue no BotFather e crie outro.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (quando rodar OpenClaw fora do cluster)
OLLAMA_HOST=http://127.0.0.1:11434

# Opcional: Google Gemini (para CEO em nuvem em fases futuras)
# GOOGLE_AI_KEY=
