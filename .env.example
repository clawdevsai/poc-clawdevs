##############################################################################
# .env.example — ClawDevs
# ──────────────────────────────────────────────────────────────────────────
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores marcados com <PREENCHER>
#   3. OU execute: make configure   (assistente interativo)
#   4. NUNCA commite o .env — ele está no .gitignore
#
# Referência: docs/09-setup-e-scripts.md | docs/07-configuracao-e-prompts.md
##############################################################################

# ─────────────────────────────────────────────────────────────────────────────
# 🔑  CHAVES DE API — OBRIGATÓRIAS
# ─────────────────────────────────────────────────────────────────────────────

# Google AI / Gemini — usada pelo CEO e PO para tarefas em nuvem
# Obter em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=<PREENCHER>

# Telegram Bot Token — bot pelo qual o Diretor interage com o enxame
# Criar bot em: https://t.me/BotFather  → /newbot
TELEGRAM_TOKEN=<PREENCHER>

# Telegram Chat ID — ID do Diretor (ou grupo) que pode comandar o enxame
# Obter em: https://t.me/userinfobot  ou  https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=<PREENCHER>

# ─────────────────────────────────────────────────────────────────────────────
# 🔑  CHAVES DE API — OPCIONAIS (podem ser adicionadas depois)
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter — modelos em nuvem alternativos / gratuitos (FreeRide)
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Trello — integração do PO com quadros Kanban
# Obter em: https://trello.com/power-ups/admin → gerar chave e token
TRELLO_API_KEY=
TRELLO_TOKEN=
# ID do board Trello principal (opcional — PO descobre automaticamente se vazio)
TRELLO_BOARD_ID=

# Maton API Gateway — 100+ APIs externas com OAuth gerenciado
# Obter em: https://maton.ai/settings
# Docs: docs/25-api-gateway-integracao-apis.md
MATON_API_KEY=

# GitHub Token — para o PO e Developer manipularem Issues/PRs via gh CLI
# Obter em: https://github.com/settings/tokens (scopes: repo, read:org)
GITHUB_TOKEN=

# Exa Web Search — busca web semântica via API
# Obter em: https://exa.ai
EXA_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# 🖥️  OLLAMA — INFERÊNCIA LOCAL
# ─────────────────────────────────────────────────────────────────────────────

# Endpoint do Ollama (dentro do cluster Kubernetes)
# Padrão para cluster local Minikube:
OLLAMA_HOST=http://ollama-service.ai-agents.svc.cluster.local:11434

# Tempo que o Ollama mantém o modelo carregado na VRAM após a última chamada
# Valores: "5m" (5 min), "0" (descarregar após cada resposta)
# Docs: docs/estrategia-uso-hardware-gpu-cpu.md
OLLAMA_KEEP_ALIVE=5m

# Modelos padrão por agente (quantizados 4-bit recomendados para RTX 3060 Ti 8GB)
OLLAMA_MODEL_DEVELOPER=deepseek-coder:6.7b
OLLAMA_MODEL_ARCHITECT=llama3:8b
OLLAMA_MODEL_QA=llama3:8b
OLLAMA_MODEL_CYBERSEC=mistral:7b
OLLAMA_MODEL_DEVOPS=phi3:mini
OLLAMA_MODEL_UX=phi3:mini
OLLAMA_MODEL_DBA=llama3:8b
OLLAMA_MODEL_CEO_LOCAL=llama3:8b
OLLAMA_MODEL_PO_LOCAL=llama3:8b

# ─────────────────────────────────────────────────────────────────────────────
# ☁️  PROVEDOR GOOGLE GEMINI (CEO / PO em nuvem)
# ─────────────────────────────────────────────────────────────────────────────

# Modelo padrão para tarefas do CEO em nuvem
GOOGLE_MODEL_CEO=gemini-1.5-pro

# Modelo para tarefas do PO em nuvem (mais barato; flash)
GOOGLE_MODEL_PO=gemini-1.5-flash

# Limite máximo de tokens por requisição ao Gemini (FinOps — Gateway)
# Docs: docs/07-configuracao-e-prompts.md (seção 2.1)
GOOGLE_MAX_TOKENS_CEO=8000
GOOGLE_MAX_TOKENS_PO=4096

# ─────────────────────────────────────────────────────────────────────────────
# 💻  HARDWARE / LIMITES DE RECURSOS (calculados automaticamente pelo setup.sh)
# ─────────────────────────────────────────────────────────────────────────────
# Os valores abaixo são gerados pelo setup.sh com base em 65% da sua máquina.
# Na máquina de referência (Ryzen 5800X / 31 GB RAM / RTX 3060 Ti 8GB):
#   MK_CPUS=10   MK_RAM_MB=20480   MK_VRAM_MB=5120
# Docs: docs/04-infraestrutura.md | docs/00-objetivo-e-maquina-referencia.md

# CPUs alocadas ao Minikube (65% do total de threads)
MK_CPUS=10

# RAM alocada ao Minikube em MB (65% do total)
MK_RAM_MB=20480

# VRAM máxima para o Ollama em MB (65% da VRAM da GPU)
MK_VRAM_MB=5120

# Driver do Minikube (docker recomendado para GPU passthrough)
MINIKUBE_DRIVER=docker

# ─────────────────────────────────────────────────────────────────────────────
# 🔴  REDIS — FILA E GPU LOCK
# ─────────────────────────────────────────────────────────────────────────────

# Host Redis dentro do cluster Kubernetes
REDIS_HOST=redis-master.ai-agents.svc.cluster.local
REDIS_PORT=6379
REDIS_DB=0

# TTL do GPU Lock (segundos)
# Docs: docs/04-infraestrutura.md (seção GPU Lock)
GPU_LOCK_TTL_SHORT=60
GPU_LOCK_TTL_LONG=120
# Limiar de linhas no payload para usar TTL longo
GPU_LOCK_PAYLOAD_THRESHOLD=500

# TTL das chaves do working buffer no Redis (segundos)
# Evita acúmulo de contexto antigo sem depender do agente DevOps
# Docs: docs/07-configuracao-e-prompts.md (seção 2.2)
REDIS_WORKING_BUFFER_TTL=3600

# ─────────────────────────────────────────────────────────────────────────────
# 💰  FINOPS — CONTROLE DE CUSTOS
# ─────────────────────────────────────────────────────────────────────────────

# Limite diário de gasto de API em USD (freio de emergência)
# Configurar também no painel do Google Cloud / Gemini
# Docs: docs/07-configuracao-e-prompts.md (seção 2.1)
DAILY_API_BUDGET_USD=5.00

# Limite de eventos de estratégia do CEO por hora (token bucket)
CEO_MAX_STRATEGY_EVENTS_PER_HOUR=5

# Percentual mínimo de aprovação CEO→PO antes do rebaixamento de modelo (%%)
CEO_APPROVAL_RATE_THRESHOLD=40

# Número de interações a partir do qual ativa o pré-voo de sumarização
SUMMARIZE_PREFLIGHT_THRESHOLD=3

# Limite de tokens do contexto antes do truncamento na borda
CONTEXT_TRUNCATION_TOKEN_LIMIT=4000

# ─────────────────────────────────────────────────────────────────────────────
# 🌡️  HARDWARE SAFETY — TEMPERATURA E CHECKPOINTS
# ─────────────────────────────────────────────────────────────────────────────

# Temperatura (°C) para gatilho pré-crítico (git stash)
# Docs: docs/07-configuracao-e-prompts.md (DevOps/SRE)
GPU_TEMP_CHECKPOINT=80

# Temperatura (°C) para pausa total dos agentes (Q-Suite)
GPU_TEMP_PAUSE=82

# Temperatura (°C) segura para retomada automática
GPU_TEMP_RESUME=65

# ─────────────────────────────────────────────────────────────────────────────
# 🤖  MODELOS — SELEÇÃO DINÂMICA E FALLBACK
# ─────────────────────────────────────────────────────────────────────────────

# Modelo de CPU leve para fallback quando GPU está indisponível ou orçamento excedido
FALLBACK_CPU_MODEL=phi3:mini

# Modelo de embeddings local (LanceDB / RAG)
# Docs: docs/28-memoria-longo-prazo-elite.md
EMBEDDING_MODEL=bge-m3

# ─────────────────────────────────────────────────────────────────────────────
# 📁  CAMINHOS E NAMESPACE
# ─────────────────────────────────────────────────────────────────────────────

# Namespace Kubernetes dos agentes
K8S_NAMESPACE=ai-agents

# Diretório raiz do enxame no host
ENXAME_DIR=${HOME}/enxame

# Diretório de transcrição de áudio
TRANSCRIPTION_DIR=${HOME}/enxame/transcription

# Diretório de saída das transcrições
AUDIO_TRANSCRIPTIONS_DIR=${HOME}/enxame/audio/transcriptions

# ─────────────────────────────────────────────────────────────────────────────
# 🔒  SEGURANÇA
# ─────────────────────────────────────────────────────────────────────────────

# Ativar modo Zero Trust (bloquear downloads sem aprovação)
ZERO_TRUST_STRICT=true

# Ativar análise de dependências antes de instalar pacotes
DEPENDENCY_QUARANTINE=true

# Habilitar egress apenas para whitelist de domínios
EGRESS_WHITELIST_ONLY=true

# ─────────────────────────────────────────────────────────────────────────────
# 📝  OPERAÇÕES
# ─────────────────────────────────────────────────────────────────────────────

# Autonomia padrão do CEO (always_ask | threshold | full_auto)
# Docs: docs/07-configuracao-e-prompts.md (seção 5)
CEO_AUTONOMY_MODE=always_ask

# Custo (USD) a partir do qual o CEO pede aprovação do Diretor
CEO_COST_APPROVAL_THRESHOLD=0.50

# Timeout do cluster acéfalo (segundos sem comando estratégico do CEO)
HEADLESS_CLUSTER_TIMEOUT=300

# Número de ciclos de health check estáveis antes de retomar após queda
HEADLESS_RESUME_STABLE_CYCLES=3
