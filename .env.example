# ClawDevs — exemplo de variáveis de ambiente
# Copie para .env e preencha: cp .env.example .env
# Nunca commitar .env com valores reais.

# =============================================================================
# TELEGRAM (interface Diretor ↔ CEO; só o CEO usa)
# =============================================================================
# TELEGRAM_BOT_TOKEN — Token do bot criado no Telegram. O gateway usa para receber e enviar mensagens do Diretor.
# Como gerar: 1) Abra https://t.me/BotFather  2) /newbot  3) Siga o assistente e copie o token (formato 123456:ABC-xxx).
TELEGRAM_BOT_TOKEN=

# TELEGRAM_CHAT_ID — ID do chat do Diretor com o bot. Garante que só esse chat recebe respostas do CEO.
# Como obter: Envie uma mensagem ao bot e acesse https://api.telegram.org/bot<SEU_BOT_TOKEN>/getUpdates; o "chat.id" é o TELEGRAM_CHAT_ID.
TELEGRAM_CHAT_ID=

# =============================================================================
# SLACK — Um app e um canal por agente (9 agentes + OpenClaw + Orquestrador)
# Objetivo: os agentes discutirem entre si no Slack. Cada um tem seu próprio app em https://api.slack.com/apps e seu canal.
# Ação: crie um app por agente em api.slack.com/apps e preencha WEBHOOK_URL ou BOT_TOKEN + ALERTS_CHANNEL_ID abaixo.
# Migração: se você usava SLACK_* sem prefixo, renomeie para OPENCLAW_SLACK_*; os scripts aceitam fallback.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenClaw (gateway: DM + canal de discussão; Socket Mode)
# Ref: https://docs.openclaw.ai/channels/slack
# -----------------------------------------------------------------------------
# OPENCLAW_SLACK_ENABLED — Se "true", o canal Slack do OpenClaw é ativado no gateway (DM + canais).
# Valor: true ou false. Deixe true para usar Slack.
OPENCLAW_SLACK_ENABLED=true

# OPENCLAW_SLACK_APP_TOKEN — App-Level Token (xapp-...) para Socket Mode. Mantém a conexão WebSocket com o Slack.
# Como gerar: Slack API → seu app OpenClaw → Settings → Socket Mode → Enable. Depois: Basic Information → App-Level Tokens → Generate (scope connections:write). Copie o token xapp-...
OPENCLAW_SLACK_APP_TOKEN=xapp-1-FAKE-openclaw-1234567890-fake

# OPENCLAW_SLACK_BOT_TOKEN — Bot User OAuth Token (xoxb-...). Usado para enviar/ler mensagens e acessar canais.
# Como gerar: No mesmo app → Install App (ou OAuth & Permissions) → Install to Workspace → copie "Bot User OAuth Token" (xoxb-...).
OPENCLAW_SLACK_BOT_TOKEN=xoxb-fake-openclaw-1234567890-fake

# OPENCLAW_SLACK_DIRECTOR_USER_ID — ID do usuário Slack do Diretor. Quem pode iniciar DM com o bot (allowlist).
# Como obter: Slack → canal ou DM → clique no nome do usuário → "View member profile" → copie "Member ID" (formato U01234ABCD). Ou: Workspace Admin → Manage members → coluna Member ID.
OPENCLAW_SLACK_DIRECTOR_USER_ID=UFAKE0DIR01

# OPENCLAW_SLACK_ALLOWED_USER_IDS — IDs de outros usuários que podem mandar DM ao bot, separados por vírgula (ex.: U123,U456).
# Como obter: Mesmo processo do DIRECTOR_USER_ID. Se vazio e DIRECTOR também vazio, o gateway usa "pairing" (openclaw pairing approve slack <CODE>).
OPENCLAW_SLACK_ALLOWED_USER_IDS=UFAKE001,UFAKE002

# OPENCLAW_SLACK_ALL_CLAWDEVSAI_CHANNEL_ID — ID do canal onde o fluxo "tema para análise" ocorre (ex.: #all-clawdevsai).
# Como obter: No Slack, abra o canal → clique no nome no topo → "View channel details" → role até o fim → "Channel ID" (ex.: C01234ABCD). Ou use link compartilhar e extraia o ID da URL.
OPENCLAW_SLACK_ALL_CLAWDEVSAI_CHANNEL_ID=CFAKEOPEN01

# -----------------------------------------------------------------------------
# Orquestrador (alertas: digest, consensus, architect fallback, freio de mão)
# Use um dos dois: WEBHOOK_URL (mais simples) OU BOT_TOKEN + ALERTS_CHANNEL_ID.
# -----------------------------------------------------------------------------
# ORCHESTRATOR_SLACK_WEBHOOK_URL — URL de Incoming Webhook. O orquestrador posta alertas nesse canal sem precisar de Bot Token.
# Como gerar: Crie um app em api.slack.com/apps (ou use o do orquestrador) → Incoming Webhooks → On → Add New Webhook to Workspace → escolha o canal → copie a URL (https://hooks.slack.com/services/...).
ORCHESTRATOR_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/ORCH/fake

# ORCHESTRATOR_SLACK_BOT_TOKEN — Bot Token (xoxb-...) do app do orquestrador. Alternativa ao webhook para postar em canal específico.
# Como gerar: No app do orquestrador: Install to Workspace → copie Bot User OAuth Token.
ORCHESTRATOR_SLACK_BOT_TOKEN=xoxb-fake-orchestrator-1234567890-fake

# ORCHESTRATOR_SLACK_ALERTS_CHANNEL_ID — ID do canal onde o orquestrador envia alertas (ex.: #alerts-orchestrator). Obrigatório se usar BOT_TOKEN em vez de WEBHOOK.
# Como obter: Canal no Slack → View channel details → Channel ID (formato C01234ABCD).
ORCHESTRATOR_SLACK_ALERTS_CHANNEL_ID=CFAKEORCH01

# -----------------------------------------------------------------------------
# 1. CEO — Estratégia, pesquisa de mercado, interface com o Diretor (discussão entre agentes)
# -----------------------------------------------------------------------------
CEO_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/CEO/fake
CEO_SLACK_APP_TOKEN=xapp-1-FAKE-ceo-1234567890-fake
CEO_SLACK_BOT_TOKEN=xoxb-fake-ceo-1234567890-fake
CEO_SLACK_ALERTS_CHANNEL_ID=CFAKECEO01

# -----------------------------------------------------------------------------
# 2. PO (Product Owner) — Backlog, priorização, Issues no GitHub, validação com Architect
# -----------------------------------------------------------------------------
PO_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/PO/fake
PO_SLACK_APP_TOKEN=xapp-1-FAKE-po-1234567890-fake
PO_SLACK_BOT_TOKEN=xoxb-fake-po-1234567890-fake
PO_SLACK_ALERTS_CHANNEL_ID=CFAKEPO01

# -----------------------------------------------------------------------------
# 3. DevOps / SRE — Infra, CI/CD, repositórios, Terraform/K8s
# -----------------------------------------------------------------------------
DEVOPS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/DEVOPS/fake
DEVOPS_SLACK_APP_TOKEN=xapp-1-FAKE-devops-1234567890-fake
DEVOPS_SLACK_BOT_TOKEN=xoxb-fake-devops-1234567890-fake
DEVOPS_SLACK_ALERTS_CHANNEL_ID=CFAKEDEVOPS01

# -----------------------------------------------------------------------------
# 4. Architect — Governança técnica, code review, ADRs, viabilidade de tarefas
# -----------------------------------------------------------------------------
ARCHITECT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/ARCH/fake
ARCHITECT_SLACK_APP_TOKEN=xapp-1-FAKE-architect-1234567890-fake
ARCHITECT_SLACK_BOT_TOKEN=xoxb-fake-architect-1234567890-fake
ARCHITECT_SLACK_ALERTS_CHANNEL_ID=CFAKEARCH01

# -----------------------------------------------------------------------------
# 5. Developer — Implementação e codificação (Ollama/OpenCode). App ID: A0AJV68FKMW.
# Bot Token do app Developer; não use o do CEO (cada agente = um app Slack).
# -----------------------------------------------------------------------------
DEVELOPER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/DEV/fake
DEVELOPER_SLACK_APP_TOKEN=xapp-1-FAKE-developer-1234567890-fake
DEVELOPER_SLACK_BOT_TOKEN=xoxb-fake-developer-1234567890-fake
DEVELOPER_SLACK_ALERTS_CHANNEL_ID=CFAKEDEV01

# -----------------------------------------------------------------------------
# 6. QA — Testes, qualidade, revisão de PRs
# -----------------------------------------------------------------------------
QA_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/QA/fake
QA_SLACK_APP_TOKEN=xapp-1-FAKE-qa-1234567890-fake
QA_SLACK_BOT_TOKEN=xoxb-fake-qa-1234567890-fake
QA_SLACK_ALERTS_CHANNEL_ID=CFAKEQA01

# -----------------------------------------------------------------------------
# 7. CyberSec (CISO/DPO) — Segurança, LGPD, OWASP, auditoria
# -----------------------------------------------------------------------------
CYBERSEC_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/CYBER/fake
CYBERSEC_SLACK_APP_TOKEN=xapp-1-FAKE-cybersec-1234567890-fake
CYBERSEC_SLACK_BOT_TOKEN=xoxb-fake-cybersec-1234567890-fake
CYBERSEC_SLACK_ALERTS_CHANNEL_ID=CFAKECYBER01

# -----------------------------------------------------------------------------
# 8. UX — Frontend, design, acessibilidade, diretrizes de UI
# -----------------------------------------------------------------------------
UX_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/UX/fake
UX_SLACK_APP_TOKEN=xapp-1-FAKE-ux-1234567890-fake
UX_SLACK_BOT_TOKEN=xoxb-fake-ux-1234567890-fake
UX_SLACK_ALERTS_CHANNEL_ID=CFAKEUX01

# -----------------------------------------------------------------------------
# 9. DBA — Banco de dados, modelagem, queries
# -----------------------------------------------------------------------------
DBA_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/FAKE/DBA/fake
DBA_SLACK_APP_TOKEN=xapp-1-FAKE-dba-1234567890-fake
DBA_SLACK_BOT_TOKEN=xoxb-fake-dba-1234567890-fake
DBA_SLACK_ALERTS_CHANNEL_ID=CFAKEDBA01

# Para as variáveis chegarem no pod openclaw: preencha *_SLACK_APP_TOKEN e *_SLACK_BOT_TOKEN no .env,
# rode ./scripts/k8s-openclaw-secret-from-env.sh e kubectl rollout restart deployment/openclaw -n ai-agents.
# WEBHOOK_URL e ALERTS_CHANNEL_ID são usados por scripts (slack_notify.py) ou por outros pods (ex.: orquestrador).

# =============================================================================
# Depuração OpenClaw
# =============================================================================
# OPENCLAW_LOG — Se "1", grava log do gateway em openclaw-gateway.log. Se caminho, grava nesse arquivo.
# Uso: OPENCLAW_LOG=1 ./scripts/run-openclaw-telegram-ollama.sh  e depois tail -f openclaw-gateway.log
# OPENCLAW_LOG=1

# =============================================================================
# Ollama (quando rodar OpenClaw fora do cluster)
# =============================================================================
# OLLAMA_HOST — URL do servidor Ollama. No host com port-forward: http://127.0.0.1:11434. No cluster: http://ollama-service.ai-agents.svc.cluster.local:11434
OLLAMA_HOST=http://127.0.0.1:11434

# =============================================================================
# Opcional: Google Gemini (CEO em nuvem em fases futuras)
# =============================================================================
# GOOGLE_AI_KEY — Chave da API Google AI (Gemini). Obter em https://aistudio.google.com/apikey
# GOOGLE_AI_KEY=

# =============================================================================
# Fase 3 — Arbitragem na nuvem (5º strike)
# =============================================================================
# OPENROUTER_API_KEY — Chave OpenRouter (openrouter.ai). Usada para arbitragem quando atinge 5º strike.
# OPENROUTER_API_KEY=
# OPENROUTER_ARBITRAGE_MODEL — Modelo para arbitragem (ex.: openai/gpt-4o-mini).
# OPENROUTER_ARBITRAGE_MODEL=openai/gpt-4o-mini
# GOOGLE_AI_KEY — Pode ser reutilizada aqui para arbitragem com Gemini.
