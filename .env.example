# ClawDevs AI - used environment variables only

# Core runtime stack
OPENCLAW_REQUIRED=true
OPENCLAW_GATEWAY_WS=ws://openclaw-gateway:18789
OPENCLAW_GATEWAY_TOKEN=local-dev-token
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
OPENCLAW_CLI_PATH=openclaw
MODEL_PROVIDER=ollama
MODEL_MODE=cloud
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3-next:80b-cloud
OLLAMA_API_KEY=

# OpenClaw model routing per role (primary + fallback)
OPENCLAW_MODEL_CEO_PRIMARY=qwen3.5:397b-cloud
OPENCLAW_MODEL_CEO_FALLBACK=qwen3-next:80b-cloud
OPENCLAW_MODEL_PO_PRIMARY=qwen3-next:80b-cloud
OPENCLAW_MODEL_PO_FALLBACK=ministral-3:14b-cloud
OPENCLAW_MODEL_ARCHITECT_DRAFT_PRIMARY=devstral-2:123b-cloud
OPENCLAW_MODEL_ARCHITECT_DRAFT_FALLBACK=qwen3.5:397b-cloud
OPENCLAW_MODEL_DEVELOPER_PRIMARY=qwen3-coder:480b-cloud
OPENCLAW_MODEL_DEVELOPER_FALLBACK=qwen3-coder-next:cloud
OPENCLAW_MODEL_QA_PRIMARY=gpt-oss:120b-cloud
OPENCLAW_MODEL_QA_FALLBACK=nemotron-3-nano:30b-cloud
OPENCLAW_MODEL_DEVOPS_PRIMARY=devstral-small-2:24b-cloud
OPENCLAW_MODEL_DEVOPS_FALLBACK=rnj-1:8b-cloud

# OpenClaw role sessions
OPENCLAW_PO_SESSION_KEY=agent:po:main
OPENCLAW_ARCHITECT_SESSION_KEY=agent:architect:main
OPENCLAW_DEVELOPER_SESSION_KEY=agent:developer:main
OPENCLAW_QA_SESSION_KEY=agent:qa:main
OPENCLAW_DEVOPS_SESSION_KEY=agent:devops:main
OPENCLAW_DBA_SESSION_KEY=agent:dba:main
OPENCLAW_CYBERSEC_SESSION_KEY=agent:cybersec:main
OPENCLAW_ARCHITECT_REVIEW_SESSION_KEY=agent:architect_review:main

# Redis / state
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
KEY_PREFIX_PROJECT=project:v1

# Streams / groups
STREAM_CMD_STRATEGY=cmd:strategy
STREAM_DRAFT_ISSUE=draft.2.issue
STREAM_PR_REVIEW=pr:review
QA_STREAM=code:ready
QA_REVIEW_STREAM=pr:review
STREAM_EVENT_DEVOPS=event:devops
STREAM_ORCHESTRATOR_EVENTS=orchestrator:events
STREAM_DIGEST=digest:daily
PO_GROUP=clawdevs
ARCHITECT_DRAFT_GROUP=clawdevs
DEVELOPER_GROUP=clawdevs
QA_GROUP=clawdevs
DEVOPS_GROUP=clawdevs
DBA_GROUP=clawdevs-dba
CYBERSEC_GROUP=clawdevs-cybersec
ARCHITECT_REVIEW_GROUP=clawdevs-architect-review
DEVELOPER_STREAM=task:backlog
STRATEGY_DOC_KEY=strategy:document
DEV_LOCK_TTL_SEC=1800

# Governance / limits
INVALID_OUTPUT_THRESHOLD=3
CONSENSUS_LOOP_TIMEOUT_SEC=120
ORCHESTRATOR_INTERVAL_SEC=30
FINOPS_MAX_ATTEMPTS=5
FINOPS_DAILY_CAP=0
FINOPS_COST_ESTIMATE=0
DEGRADATION_THRESHOLD_PCT=0
DEGRADATION_REPORT_DIR=

# Paths / QA
MEMORY_MD_PATH=
AREAS_QA_AUDIT_PATH=

# Cosmetic flow (used by contingency/runtime tooling)
COSMETIC_TIMER_HOURS=
COSMETIC_EXTENSIONS=

# GitHub
GITHUB_REPO=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_ADMIN_TOKEN=
GITHUB_WEBHOOK_HOST=0.0.0.0
GITHUB_WEBHOOK_PORT=8081
GITHUB_WEBHOOK_PATH=/webhook/github

# Telegram director <-> CEO chat bridge
TELEGRAM_ENABLE_WEB_SEARCH=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
