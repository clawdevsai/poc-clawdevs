# ClawDevs — variáveis de ambiente (nunca commitar .env com valores reais)
# Um app Slack por agente; preencha cada bloco ao criar os apps em api.slack.com/apps
# Ref: docs/42-slack-tokens-setup.md

# =============================================================================
# TELEGRAM (interface Diretor ↔ CEO)
# =============================================================================
TELEGRAM_BOT_TOKEN=8376610224:AAFCz461vSji5iKlXF_...
TELEGRAM_CHAT_ID=7299920006

# =============================================================================
# SLACK — OpenClaw (gateway: DM + canal; Socket Mode)
# Conexão default = app CEO (A0AHYC7MWKY); app A0AHT21DYKD não existe mais → account_inactive
# =============================================================================
OPENCLAW_SLACK_ENABLED=true
OPENCLAW_SLACK_APP_TOKEN=xapp-1-A0AHYC7MWKY-...
OPENCLAW_SLACK_BOT_TOKEN=xoxb-10601006973077-...
OPENCLAW_SLACK_DIRECTOR_USER_ID=U0AHL10Q...
OPENCLAW_SLACK_ALL_CLAWDEVSAI_CHANNEL_ID=C0AHSCLS...
# Slash Commands: api.slack.com → app → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=132cf377ea11642a038c54c422...
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# =============================================================================
# SLACK — Orquestrador (alertas: digest, consensus, architect fallback)
# Criar app em api.slack.com → usar WEBHOOK_URL ou BOT_TOKEN + ALERTS_CHANNEL_ID
# =============================================================================
ORCHESTRATOR_SLACK_WEBHOOK_URL=
ORCHESTRATOR_SLACK_BOT_TOKEN=
ORCHESTRATOR_SLACK_ALERTS_CHANNEL_ID=C0AHSCLS...

# =============================================================================
# SLACK — 1 app por agente (preencher ao criar cada app no Slack)
# Validar com anotation.txt: cada agente = um app; APP_TOKEN e BOT_TOKEN do MESMO app (nunca reutilizar de outro).
# O gateway orquestra: entrypoint injeta accounts por PREFIX; bindings mapeiam accountId → agentId → SOUL.
# =============================================================================

# 1. CEO (App ID: A0AHYC7MWKY — anotation.txt)
CEO_SLACK_WEBHOOK_URL=
CEO_SLACK_APP_TOKEN=xapp-1-A0AHYC7MWKY-10597028518535-...
CEO_SLACK_BOT_TOKEN=xoxb-10601006973077-10610425235334-...
CEO_SLACK_ALERTS_CHANNEL_ID=C0AHSCLS...

# 2. PO (Product Owner) — App ID: A0AHU4HC3U3 (anotation.txt)
PO_SLACK_WEBHOOK_URL=
PO_SLACK_APP_TOKEN=xapp-1-A0AHU4HC3U3-10616212724468-...
PO_SLACK_BOT_TOKEN=xoxb-10601006973077-10640807299792-...
PO_SLACK_ALERTS_CHANNEL_ID=C0AHSCL...

# 3. DevOps / SRE — preencher APP_TOKEN + BOT_TOKEN para o gateway conectar; WEBHOOK/ALERTS para scripts
DEVOPS_SLACK_WEBHOOK_URL=
DEVOPS_SLACK_APP_TOKEN=
DEVOPS_SLACK_BOT_TOKEN=
DEVOPS_SLACK_ALERTS_CHANNEL_ID=

# 4. Architect
ARCHITECT_SLACK_WEBHOOK_URL=
ARCHITECT_SLACK_APP_TOKEN=
ARCHITECT_SLACK_BOT_TOKEN=
ARCHITECT_SLACK_ALERTS_CHANNEL_ID=

# 5. Developer (App ID: A0AJV68FKMW — NÃO use o BOT_TOKEN do CEO)
DEVELOPER_SLACK_WEBHOOK_URL=
DEVELOPER_SLACK_APP_TOKEN=xapp-1-A0AJV68FKMW-10625869574561...
DEVELOPER_SLACK_BOT_TOKEN=xoxb-10601006973077-10641305168656...
DEVELOPER_SLACK_ALERTS_CHANNEL_ID=C0AHSCLS...

# 6. QA
QA_SLACK_WEBHOOK_URL=
QA_SLACK_APP_TOKEN=xapp-1-A0AJ554AY4C-10641850514752-...
QA_SLACK_BOT_TOKEN=xoxb-10601006973077-10617154159636-...
QA_SLACK_ALERTS_CHANNEL_ID=C0AHSCLS...

# 7. CyberSec (CISO/DPO)
CYBERSEC_SLACK_WEBHOOK_URL=
CYBERSEC_SLACK_APP_TOKEN=
CYBERSEC_SLACK_BOT_TOKEN=
CYBERSEC_SLACK_ALERTS_CHANNEL_ID=

# 8. UX
UX_SLACK_WEBHOOK_URL=
UX_SLACK_APP_TOKEN=
UX_SLACK_BOT_TOKEN=
UX_SLACK_ALERTS_CHANNEL_ID=

# 9. DBA
DBA_SLACK_WEBHOOK_URL=
DBA_SLACK_APP_TOKEN=
DBA_SLACK_BOT_TOKEN=
DBA_SLACK_ALERTS_CHANNEL_ID=

# Para as variáveis chegarem no pod openclaw: preencha *_SLACK_APP_TOKEN e *_SLACK_BOT_TOKEN,
# rode ./scripts/k8s-openclaw-secret-from-env.sh e kubectl rollout restart deployment/openclaw -n ai-agents.
# WEBHOOK_URL e ALERTS_CHANNEL_ID são usados por scripts (ex.: slack_notify.py) ou por outros pods (ex.: orquestrador).

# =============================================================================
# Git / GitHub (gh CLI e operações git que precisam de autenticação)
# Para ter acesso ao git (push, pull, gh issue, gh pr, etc.) defina o token no .env.
# O gh CLI usa GH_TOKEN; GITHUB_TOKEN é usado por várias ferramentas. Nunca commitar .env.
# Ref: docs/20-ferramenta-github-gh.md
# =============================================================================
# GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Ollama / depuração
# =============================================================================
OLLAMA_HOST=http://127.0.0.1:11434
OPENCLAW_LOG=1
