# ClawDevs AI - used environment variables only

# Core runtime stack
OPENCLAW_REQUIRED=true
OPENCLAW_GATEWAY_WS=ws://openclaw-gateway:18789
OPENCLAW_GATEWAY_TOKEN=local-dev-token
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
OPENCLAW_CLI_PATH=openclaw
MODEL_PROVIDER=ollama
MODEL_MODE=local
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:32b

# OpenClaw role sessions
OPENCLAW_PO_SESSION_KEY=agent:po:main
OPENCLAW_ARCHITECT_SESSION_KEY=agent:architect:main
OPENCLAW_DEVELOPER_SESSION_KEY=agent:developer:main
OPENCLAW_DEVOPS_SESSION_KEY=agent:devops:main

# Redis / state
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
KEY_PREFIX_PROJECT=project:v1

# Streams / groups
STREAM_CMD_STRATEGY=cmd:strategy
STREAM_DRAFT_ISSUE=draft.2.issue
STREAM_EVENT_DEVOPS=event:devops
STREAM_ORCHESTRATOR_EVENTS=orchestrator.events
STREAM_DIGEST=digest.daily
PO_GROUP=clawdevs
ARCHITECT_DRAFT_GROUP=clawdevs
DEVELOPER_GROUP=clawdevs
DEVOPS_GROUP=clawdevs
DEVELOPER_STREAM=task:backlog
STRATEGY_DOC_KEY=strategy:document
DEV_LOCK_TTL_SEC=1800

# Governance / limits
INVALID_OUTPUT_THRESHOLD=3
CONSENSUS_LOOP_TIMEOUT_SEC=120
ORCHESTRATOR_INTERVAL_SEC=30
FINOPS_MAX_ATTEMPTS=5
FINOPS_DAILY_CAP=0
FINOPS_COST_ESTIMATE=0
DEGRADATION_THRESHOLD_PCT=0
DEGRADATION_REPORT_DIR=

# Paths / QA
MEMORY_MD_PATH=
AREAS_QA_AUDIT_PATH=

# Cosmetic flow (used by contingency/runtime tooling)
COSMETIC_TIMER_HOURS=
COSMETIC_EXTENSIONS=

# Legacy aliases still referenced
GITHUB_REPO=
GH_REPO=

# Telegram director <-> CEO chat bridge
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
