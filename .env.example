#
# ClawDevs AI — Docker Compose Environment
# Copie para .env e preencha com os valores reais antes de executar 'make up'.
#
# Os nomes das variaveis sao identicos ao container/.env para facilitar a migracao.

# ─── OpenClaw Gateway ──────────────────────────────────────────────────────────
# Token Bearer para requisicoes internas entre os servicos
OPENCLAW_GATEWAY_TOKEN=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Token do bot Telegram do CEO (formato: <id>:<hash>)
TELEGRAM_BOT_TOKEN_CEO=
# Chat ID do Telegram do CEO para notificacoes
TELEGRAM_CHAT_ID_CEO=

# ─── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token com permissoes: repo, read:org, write:issues
GIT_TOKEN=
# Organizacao GitHub onde os repositorios estao hospedados (acesso a todos os repos via gh; contexto ativo em active_repository.env ou claw-repo-switch)
GIT_ORG=

# ─── Identidade do Agente ──────────────────────────────────────────────────────
# Nome do diretor/CEO exibido nas comunicacoes
DIRECTORS_NAME=
# Idioma padrao das respostas dos agentes
LANGUAGE=pt-BR

# ─── LLM Backend ──────────────────────────────────────────────────────────────
# Provedor LLM: ollama (local) | openrouter (nuvem)
PROVEDOR_LLM=ollama
# API Key da instancia Ollama (deixar vazio para desabilitar autenticacao).
# Carregada por scripts/docker/up-all.sh e up-service.sh (make up / make up-ollama) e
# passada ao container clawdevs-ollama; tambem usada pelo OpenClaw em run-openclaw.sh.
OLLAMA_API_KEY=
# OpenRouter (necessario apenas quando PROVEDOR_LLM=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=stepfun/step-3.5-flash:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Ollama: Modelos ───────────────────────────────────────────────────────────
# true  = baixa no boot os modelos em OLLAMA_BOOT_MODELS (padrao)
# false = nao baixa no boot (economiza tempo/banda em dev)
OLLAMA_AUTO_PULL_MODELS=true
# Modelos para baixar no boot (separados por espaco)
# O nomic-embed-text e necessario para memorySearch dos agentes
OLLAMA_BOOT_MODELS=nomic-embed-text

# ─── Control Panel: Auth ───────────────────────────────────────────────────────
# Chave secreta JWT (gere com: openssl rand -hex 32)
PANEL_SECRET_KEY=
# Credenciais do usuario administrador do painel
PANEL_ADMIN_USERNAME=admin
PANEL_ADMIN_PASSWORD=
# Senha do banco de dados PostgreSQL
PANEL_DB_PASSWORD=
# Senha do Redis
PANEL_REDIS_PASSWORD=

# ─── SearXNG ───────────────────────────────────────────────────────────────────
# Chave secreta da instancia SearXNG (gere com: openssl rand -hex 32)
SEARXNG_SECRET=

# ─── Schedules dos Agentes (cron expressions) ─────────────────────────────────
# Controle quando cada agente verifica sua fila de tarefas
DEV_BACKEND_CRON_ENABLED=true
DEV_BACKEND_CRON_EXPR=0 * * * *
DEV_FRONTEND_CRON_ENABLED=true
DEV_FRONTEND_CRON_EXPR=15 * * * *
DEV_MOBILE_CRON_ENABLED=true
DEV_MOBILE_CRON_EXPR=30 * * * *
QA_CRON_ENABLED=true
QA_CRON_EXPR=45 * * * *
DEVOPS_SRE_CRON_ENABLED=true
DEVOPS_SRE_CRON_EXPR=*/30 * * * *
SECURITY_ENGINEER_CRON_ENABLED=true
SECURITY_ENGINEER_CRON_EXPR=0 */6 * * *
UX_DESIGNER_CRON_ENABLED=true
UX_DESIGNER_CRON_EXPR=0 */4 * * *
DBA_DATA_ENGINEER_CRON_ENABLED=true
DBA_DATA_ENGINEER_CRON_EXPR=30 */4 * * *
MEMORY_CURATOR_CRON_ENABLED=true
MEMORY_CURATOR_CRON_EXPR=0 2 * * *

# ─── Semantic Optimization: Feature Flags (Week 4 - Rollout Strategy) ────────
# Cada tarefa pode ser ativada independentemente para rollout incremental
# false = desativado | true = ativado globalmente
PANEL_SEMANTIC_OPT_QUERY_ENHANCEMENT=false
PANEL_SEMANTIC_OPT_SEMANTIC_RERANKING=false
PANEL_SEMANTIC_OPT_ADAPTIVE_COMPRESSION=false
PANEL_SEMANTIC_OPT_SUMMARIZATION=false
PANEL_SEMANTIC_OPT_CATEGORIZATION=false
PANEL_SEMANTIC_OPT_ANOMALY_DETECTION=false
PANEL_SEMANTIC_OPT_CONTEXT_SUGGESTION=false
# Agentes em teste canary (comma-separated): ativa tarefas para agentes especificos
# Exemplo: PANEL_SEMANTIC_OPT_CANARY_AGENTS=dev_backend,memory_curator
PANEL_SEMANTIC_OPT_CANARY_AGENTS=

# ─── Debug ─────────────────────────────────────────────────────────────────────
OPENCLAW_LOG_LEVEL=error
OPENCLAW_SANDBOX_MODE=off
OPENCLAW_EXEC_POLICY=allowlist
# SearXNG: web-search usa este host (proxy nginx; default rede Docker clawdevs-searxng-proxy)
SEARXNG_BASE_URL=http://searxng-proxy:18080
# OpenClaw: ceo e po recebem exec security=full no bootstrap (09-openclaw-config.sh); demais agentes seguem OPENCLAW_EXEC_POLICY
DEBUG_LOG_ENABLED=false

# ─── Build das Imagens ─────────────────────────────────────────────────────────
# remote = usa imagens pre-buildadas do Docker Hub (clawdevsai/*)
# local  = builda localmente via 'make dc-build'
PUSH_IMAGE=remote
