# Dockerfile.base — ClawDevs: imagem base para agentes
# Multi-stage build para imagem enxuta (~300 MB sem o modelo LLM).
# Modelos ficam em PVC compartilhado, não na imagem.
#
# Referência: docs/issues/008-docker-multi-stage-imagens-agentes.md | docs/04-infraestrutura.md
#
# Build:
#   docker build -f Dockerfile.base -t clawdevs/agent-base:latest .
# Variáveis de ambiente obrigatórias no pod:
#   AGENT_NAME, REDIS_HOST, OLLAMA_BASE_URL, POD_NAME

# ─── Stage 1: Build (instalar dependências) ───────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /build

# Variáveis para build otimizado
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Instalar apenas dependências essenciais para compilação
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copiar requirements e instalar em /root/.local
COPY requirements.base.txt .
RUN pip install --user --no-cache-dir -r requirements.base.txt

# ─── Stage 2: Runtime (imagem final enxuta) ───────────────────────────────────
FROM python:3.11-slim AS runtime

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/root/.local/bin:${PATH}"

# Runtime mínimo: git para operações de repositório, curl para health checks
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Copiar dependências Python do stage de build
COPY --from=builder /root/.local /root/.local

# Copiar código do projeto
COPY orchestrator/ /app/orchestrator/
COPY memory/ /app/memory/
COPY security/ /app/security/
COPY config/ /app/config/
COPY soul/ /app/soul/
COPY scripts/gpu_lock.py /app/scripts/

# Criar diretórios de runtime
RUN mkdir -p /app/memory/hot /app/memory/warm /app/memory/cold /app/workspace

# Labels de metadados
LABEL project="clawdevs" \
      maintainer="Diego Silva Morais" \
      description="ClawDevs Agent Base Image — multi-stage, enxuta, sem modelos LLM"

# Usuário não-root para segurança
RUN useradd -r -s /bin/false -m -d /app clawagent
USER clawagent

# Health check padrão (pods devem sobrescrever se necessário)
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "import redis; r=redis.Redis(host='redis-service'); r.ping()" || exit 1

# Ponto de entrada padrão (sobrescrever por agente)
CMD ["python", "-m", "orchestrator.consumers.base_consumer"]
