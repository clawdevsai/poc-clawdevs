# NUNCA commitar secret.yaml com valores reais.
# Copie para secret.yaml e preencha; kubectl apply -f secret.yaml
# Ou crie o secret via:
#   kubectl create secret generic openclaw-telegram -n ai-agents \
#     --from-literal=TELEGRAM_BOT_TOKEN='SEU_TOKEN' \
#     --from-literal=TELEGRAM_CHAT_ID='SEU_CHAT_ID'
#
# TELEGRAM_CHAT_ID: Nao use o numero da URL do bot (8376610224 = ID do BOT).
#   Esse e o ID do CHAT para onde o bot envia mensagens (seu usuario ou grupo).
#   Como obter: envie "/start" ou qualquer msg ao bot, depois abra no browser:
#   https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
#   Na resposta JSON, use o valor de message.chat.id
# curl -s "https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates"
#
# OLLAMA_API_KEY (opcional): para Ollama Cloud (registry.ollama.ai). Para Ollama local no cluster, use "ollama-local" ou deixe em branco.
---
apiVersion: v1
kind: Secret
metadata:
  name: openclaw-telegram
  namespace: ai-agents
type: Opaque
stringData:
  TELEGRAM_BOT_TOKEN: "<TELEGRAM_BOT_TOKEN>"
  TELEGRAM_CHAT_ID: "<COLE_SEU_CHAT_ID_NUMERICO>"
  # Opcional: chave Ollama Cloud. Para uso 100% local (Ollama no cluster) nao e necessaria.
  # OLLAMA_API_KEY: "<SUA_CHAVE_OLLAMA_CLOUD>"
