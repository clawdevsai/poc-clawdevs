{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEO Input Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "delegar_po",
        "delegar_agente",
        "consultar",
        "autorizar",
        "alertar",
        "planejar",
        "executar",
        "status"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "diretor",
        "po",
        "arquiteto",
        "dev_backend",
        "sistema",
        "usuario"
      ]
    },
    "auth_token": {
      "type": "string",
      "minLength": 6
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brief_id": {
          "type": "string",
          "pattern": "^BRIEF-\\d+(?:-[a-z0-9-]+)?$"
        },
        "project_type": {
          "type": "string",
          "enum": ["web", "mobile", "desktop", "api", "saas", "automation", "data", "ai", "other"]
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "deadline": {
          "type": "string"
        },
        "cost_estimate": {
          "type": "number",
          "minimum": 0
        },
        "data_classification": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "nao"]
        }
      },
      "required": ["brief_id"]
    }
  },
  "required": ["intent", "source"]
}
