# Copie para k8s/.env e preencha com os valores reais antes de rodar o kustomize/kubectl

# Token de autenticação do gateway OpenClaw (Bearer token das requisições internas)
OPENCLAW_GATEWAY_TOKEN=

# Token do bot Telegram do CEO (formato: <id>:<hash>)
TELEGRAM_BOT_TOKEN_CEO=

# Chat ID do Telegram do CEO para notificações e escalações
TELEGRAM_CHAT_ID_CEO=

# Personal Access Token do GitHub com permissões: repo, read:org, write:issues
GITHUB_TOKEN=

# Organização GitHub onde os repositórios dos projetos estão hospedados
GITHUB_ORG=

# Repositório padrão no formato org/repo (usado como fallback pelos agentes)
GITHUB_DEFAULT_REPOSITORY=

# Nome do diretor/CEO exibido nas comunicações e relatórios dos agentes
DIRECTORS_NAME=

# API Key da instância Ollama (deixar vazio se não usar autenticação)
OLLAMA_API_KEY=

# Provedor LLM principal: ollama | openrouter
# ollama  -> usa instância local Ollama (padrão)
# openrouter -> usa OpenRouter como provider (requer OPENROUTER_API_KEY)
PROVEDOR_LLM=ollama

# API Key do OpenRouter (necessário apenas quando PROVEDOR_LLM=openrouter)
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Modelo OpenRouter opcional (sem o prefixo "openrouter/" ou com ele).
# Ex.: stepfun/step-3.5-flash:free
OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Base URL OpenRouter opcional (schema atual exige string em models.providers.openrouter.baseUrl).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Nível de log do gateway: debug | info | warn | error
OPENCLAW_LOG_LEVEL=info

# O OpenClaw roda via imagem pré-configurada `clawdevsai/openclaw-runtime:latest`
# (definida em `k8s/base/openclaw-pod.yaml`) para evitar apt/install durante o startup.

# Habilita log detalhado de debug nos containers (true | false)
DEBUG_LOG_ENABLED=false

# Ollama: pulls no boot estao habilitados em k8s/base/ollama-pod.yaml
# (OLLAMA_AUTO_PULL_MODELS + OLLAMA_BOOT_MODELS), alinhados aos ids em
# k8s/base/bootstrap-scripts/09-openclaw-config.sh (+ nomic-embed-text para memorySearch).
# Para desligar ou enxugar modelos, edite o manifest (nao e lido deste .env).

# Diretório raiz onde o dev_backend persiste artefatos de implementação
DEV_BACKEND_PROJECT_ROOT=/data/openclaw/projects

# Idioma padrão das respostas e artefatos gerados pelos agentes
LANGUAGE=pt-BR

# Controle de origem das imagens no deploy:
# local  -> builda imagens localmente no Minikube antes do apply
# remote -> usa pull das imagens publicadas no Docker Hub (clawdevsai/*)
PUSH_IMAGE=remote

# ─── Schedules dos agentes ───────────────────────────────────────────────────
# Os schedules são definidos diretamente no pod manifest (k8s/base/openclaw-pod.yaml)
# com valores hardcoded. Alterar estes comentários NÃO afeta o comportamento em runtime.
# Para mudar o schedule de um agente, edite o env var correspondente no pod.yaml:
#
DEV_BACKEND_CRON_EXPR="0 */2 * * *"
DEV_FRONTEND_CRON_EXPR="15 */2 * * *"
DEV_MOBILE_CRON_EXPR="30 */2 * * *"
QA_CRON_EXPR="45 */2 * * *"
DEVOPS_SRE_CRON_EXPR="0 * * * *"
SECURITY_ENGINEER_CRON_EXPR="0 2 * * *"
UX_DESIGNER_CRON_EXPR="0 9 * * 1"
DBA_DATA_ENGINEER_CRON_EXPR="30 9 * * 1"

# --- Control Panel ---

# Idioma padrão das respostas e artefatos gerados pelos agentes
LANGUAGE=pt-BR

# Controle de origem das imagens no deploy:
# local  -> builda imagens localmente no Minikube antes do apply
# remote -> usa pull das imagens publicadas no Docker Hub (clawdevsai/*)
PUSH_IMAGE=remote

# ─── Schedules dos agentes ───────────────────────────────────────────────────
# Os schedules são definidos diretamente no pod manifest (k8s/base/openclaw-pod.yaml)
# com valores hardcoded. Alterar estes comentários NÃO afeta o comportamento em runtime.
# Para mudar o schedule de um agente, edite o env var correspondente no pod.yaml:
#
DEV_BACKEND_CRON_EXPR="0 */2 * * *"
DEV_FRONTEND_CRON_EXPR="15 */2 * * *"
DEV_MOBILE_CRON_EXPR="30 */2 * * *"
QA_CRON_EXPR="45 */2 * * *"
DEVOPS_SRE_CRON_EXPR="0 * * * *"
SECURITY_ENGINEER_CRON_EXPR="0 2 * * *"
UX_DESIGNER_CRON_EXPR="0 9 * * 1"
DBA_DATA_ENGINEER_CRON_EXPR="30 9 * * 1"

# --- Control Panel ---
PANEL_SECRET_KEY=change-me-very-long-random-string
PANEL_ADMIN_USERNAME=admin
PANEL_ADMIN_PASSWORD=change-me
PANEL_DB_PASSWORD=change-me-db
PANEL_REDIS_PASSWORD=change-me-redis

# Chave secreta do SearXNG (gerada automaticamente se não definida — recomendado definir explicitamente)
SEARXNG_SECRET=change-me-searxng-secret-key

# -----------------------------------------------------------------------------
# 5. AJUSTES DE PERFORMANCE (MINIKUBE / DOCKER DESKTOP)
# -----------------------------------------------------------------------------

# Recomendacao para 32GB RAM / Ryzen 7 5800X:
# Memory: 24GB (24576) deixa 8GB para o Windows Host
# CPUs: 12 (de 16 logical processors) para evitar throttle extremo
MINIKUBE_MEMORY=24576
MINIKUBE_CPUS=12
