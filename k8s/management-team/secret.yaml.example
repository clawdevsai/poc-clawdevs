# NUNCA commitar secret.yaml com valores reais.
# Copie para secret.yaml e preencha; kubectl apply -f secret.yaml
# Ou: kubectl create secret generic openclaw-telegram -n ai-agents \
#       --from-literal=TELEGRAM_BOT_TOKEN='...' --from-literal=TELEGRAM_CHAT_ID='...'
---
apiVersion: v1
kind: Secret
metadata:
  name: openclaw-telegram
  namespace: ai-agents
type: Opaque
stringData:
  TELEGRAM_BOT_TOKEN: "<TELEGRAM_BOT_TOKEN>"
  TELEGRAM_CHAT_ID: "<COLE_SEU_CHAT_ID_NUMERICO>"
