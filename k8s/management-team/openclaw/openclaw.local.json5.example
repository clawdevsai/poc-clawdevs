{
  // Example: config para rodar OpenClaw no host (emergência/debug). Uso normal: tudo no K8s (make up).
  // Uso local: scripts/run-openclaw-telegram-slack-ollama.sh (port-forward Ollama + este arquivo).
  gateway: {
    mode: "local",
    port: 18789,
    bind: "loopback",
  },
  channels: {
    telegram: {
      enabled: true,
      dmPolicy: "pairing",
      allowFrom: [],
      groups: {},
    },
    slack: {
      enabled: false,
      mode: "socket",
      dmPolicy: "allowlist",
      allowFrom: [],
      dm: { enabled: true, groupEnabled: false },
      groupPolicy: "allowlist",
      channels: {},
    },
  },
  models: {
    mode: "merge",
    providers: {
      ollama: {
        baseUrl: "http://127.0.0.1:11434",
        api: "ollama",
        models: [
          { id: "deepseek-r1:8b", name: "DeepSeek R1 8B (local, padrão)", contextWindow: 32000, maxTokens: 4096 },
          { id: "deepseek-r1:14b", name: "DeepSeek R1 14B (local, CEO)", contextWindow: 32000, maxTokens: 8192 },
          { id: "ministral-3:3b", name: "Ministral 3 3B (local)", contextWindow: 32000, maxTokens: 4096 },
          { id: "stewyphoenix19/phi3-mini_v1:latest", name: "Phi3 Mini v1 (local, leve)", contextWindow: 16000, maxTokens: 1024 },
        ],
      },
    },
  },
  agents: {
    defaults: {
      model: "ollama/glm-5:cloud",
      workspace: "",
      subagents: {
        maxSpawnDepth: 2,
        maxChildrenPerAgent: 5,
        maxConcurrent: 4,
        runTimeoutSeconds: 600,
        model: "ollama/glm-5:cloud",
      },
    },
    list: [
      { id: "ceo", name: "CEO", model: "ollama/glm-5:cloud", description: "Estratégia e interface com o Diretor." },
      { id: "po", name: "Product Owner", model: "ollama/glm-5:cloud", description: "Backlog e priorização." },
      { id: "devops", name: "DevOps/SRE", model: "ollama/glm-5:cloud", description: "IaC, CI/CD, FinOps." },
      { id: "architect", name: "Architect", model: "ollama/glm-5:cloud", description: "Governança técnica, code review." },
      { id: "developer", name: "Developer", model: "ollama/glm-5:cloud", description: "Implementação." },
      { id: "qa", name: "QA", model: "ollama/glm-5:cloud", description: "Testes e qualidade." },
      { id: "cybersec", name: "CyberSec", model: "ollama/glm-5:cloud", description: "Segurança." },
      { id: "ux", name: "UX", model: "ollama/glm-5:cloud", description: "Experiência do usuário." },
      { id: "dba", name: "DBA", model: "ollama/glm-5:cloud", description: "Dados e queries." },
    ],
  },
  bindings: [
    { match: { channel: "telegram" }, agentId: "ceo" },
  ],
}
