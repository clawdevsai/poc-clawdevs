# .gitignore — ClawDevs
# Ignorar arquivos sensíveis, temporários e gerados automaticamente.

# ─── Segredos e chaves (NUNCA commitar) ──────────────────────────────────────
.env
.env.*
*.key
*.pem
*.crt
secrets/
**/secrets.yaml
**/clawdevs-secrets.yaml
config.yaml                # OpenClaw config com API keys
~/enxame/openclaw/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.egg
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage.xml
.coverage
htmlcov/

# ─── Node.js (para projetos desenvolvidos pelo enxame) ───────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnpm-lock.yaml

# ─── Docker ──────────────────────────────────────────────────────────────────
*.dockerignore

# ─── Kubernetes / Minikube ────────────────────────────────────────────────────
.minikube/
kubeconfig
*.kubeconfig

# ─── Modelos LLM (ficam em volumes PVC, não no repositório) ──────────────────
*.gguf
*.bin
*.safetensors
models/

# ─── Transcrições de áudio (dados do usuário) ────────────────────────────────
*.m4a
*.mp3
*.wav
*.mp4
transcriptions/
audio/

# ─── Memória e estado dos agentes (runtime, não versionado) ──────────────────
memory/hot/
memory/warm/adrs/
memory/cold/
memory/wal/
MEMORY.md              # Gerado automaticamente; auditar via K8s
VFM_CEO_score.json

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── IDEs ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── Temporários ─────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
__pycache__/

# ─── Arquivos de CI/CD gerados ────────────────────────────────────────────────
.semgrep/

# ─── WAL (Write-Ahead Log — gerado em runtime) ────────────────────────────────
memory/wal/*.json
.venv/
*.pyc
__pycache__/
.coverage
htmlcov/

